<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.whim.system.mapper.SysPermissionMapper">

    <resultMap id="SysPermissionMap" type="com.whim.system.model.entity.SysPermission">
        <id property="id" column="id" jdbcType=""/>
        <result property="name" column="name" jdbcType=""/>
        <result property="title" column="title" jdbcType=""/>
        <result property="parentId" column="parent_id" jdbcType=""/>
        <result property="type" column="type" jdbcType=""/>
        <result property="path" column="path" jdbcType=""/>
        <result property="queryParam" column="query_param" jdbcType=""/>
        <result property="component" column="component" jdbcType=""/>
        <result property="keepAlive" column="keep_alive" jdbcType=""/>
        <result property="sort" column="sort" jdbcType=""/>
        <result property="code" column="perms" jdbcType=""/>
        <result property="visible" column="visible" jdbcType=""/>
        <result property="status" column="status" jdbcType=""/>
        <result property="icon" column="icon" jdbcType=""/>
        <result property="redirect" column="redirect" jdbcType=""/>
        <result property="remark" column="remark" jdbcType=""/>
        <result property="createBy" column="create_by" jdbcType=""/>
        <result property="createTime" column="create_time" jdbcType=""/>
        <result property="updateBy" column="update_by" jdbcType=""/>
        <result property="updateTime" column="update_time" jdbcType=""/>
        <result property="deleted" column="deleted" jdbcType=""/>
    </resultMap>

    <select id="selectPermissionCodeSetByUserId" resultType="java.lang.String">
        SELECT p.perms
        FROM sys_user_role ur
                 INNER JOIN sys_role r
                            ON r.id = ur.role_id
                                AND r.deleted = 0
                                AND r.status = 0
                 INNER JOIN sys_role_permission rp
                            ON rp.role_id = r.id
                                AND rp.tenant_id = ur.tenant_id
                                AND rp.deleted = 0
                 INNER JOIN sys_permission p
                            ON p.id = rp.permission_id
                                AND p.deleted = 0
                                AND p.status = 0
        WHERE ur.user_id = #{userId}
          AND ur.deleted = 0
    </select>

</mapper>
