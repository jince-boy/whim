<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.whim.system.mapper.SysRoleMapper">

    <resultMap id="SysRoleMap" type="com.whim.system.model.entity.SysRole">
        <id property="id" column="id" jdbcType=""/>
        <result property="name" column="name" jdbcType=""/>
        <result property="code" column="role_code" jdbcType=""/>
        <result property="dataScope" column="data_scope" jdbcType=""/>
        <result property="description" column="description" jdbcType=""/>
        <result property="status" column="status" jdbcType=""/>
        <result property="remark" column="remark" jdbcType=""/>
        <result property="createBy" column="create_by" jdbcType=""/>
        <result property="createTime" column="create_time" jdbcType=""/>
        <result property="updateBy" column="update_by" jdbcType=""/>
        <result property="updateTime" column="update_time" jdbcType=""/>
        <result property="deleted" column="deleted" jdbcType=""/>
    </resultMap>

    <select id="selectRoleCodeSetByUserId" resultType="java.lang.String">
        SELECT r.role_code
        FROM sys_user_role ur
                 INNER JOIN sys_role r
                            ON r.id = ur.role_id
                                AND r.deleted = 0
                                AND r.status = 0
        WHERE ur.user_id = #{userId}
          AND ur.deleted = 0
    </select>

</mapper>
